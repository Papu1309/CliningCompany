<Page x:Class="CliningCompany.Pages.AdminMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Администрирование" Background="LightGray">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Панель администратора" FontSize="18" FontWeight="Bold" Margin="10"/>

        <ListView x:Name="lvMenu" Grid.Row="1" Margin="10" Background="Transparent" BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#ccc" BorderThickness="1" Margin="5" Padding="10" CornerRadius="5" Background="#f9f9f9">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Description}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button x:Name="btnLogout" Content="Выход" Grid.Row="2" Width="100" Height="30" Margin="10" HorizontalAlignment="Right" Click="btnLogout_Click"/>
    </Grid>
</Page>