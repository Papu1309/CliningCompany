<Page x:Class="CliningCompany.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация" Background="LightGray">
    <Grid>
        <Grid Width="350" Height="300" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Полное имя:" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="txtFullName" Grid.Row="0" Grid.Column="1" Margin="5" Padding="3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Логин:" Margin="5" VerticalAlignment="Center"/>
            <TextBox x:Name="txtUsername" Grid.Row="1" Grid.Column="1" Margin="5" Padding="3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Пароль:" Margin="5" VerticalAlignment="Center"/>
            <PasswordBox x:Name="txtPassword" Grid.Row="2" Grid.Column="1" Margin="5" Padding="3"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Подтвердите:" Margin="5" VerticalAlignment="Center"/>
            <PasswordBox x:Name="txtConfirmPassword" Grid.Row="3" Grid.Column="1" Margin="5" Padding="3"/>

            <Button x:Name="btnRegister" Content="Зарегистрироваться" Grid.Row="4" Grid.ColumnSpan="2" Width="150" Margin="5" Click="btnRegister_Click"/>
            <Button x:Name="btnBack" Content="Назад" Grid.Row="5" Grid.ColumnSpan="2" Width="100" Margin="5" Click="btnBack_Click"/>
        </Grid>
    </Grid>
</Page>