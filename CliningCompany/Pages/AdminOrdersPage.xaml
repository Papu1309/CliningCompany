<Page x:Class="CliningCompany.Pages.AdminOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы" Background="LightGray">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Все заказы" FontSize="16" Margin="5"/>

        <!-- Фильтр по статусу -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
            <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="cmbStatusFilter" Width="120" SelectionChanged="cmbStatusFilter_SelectionChanged">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="paid"/>
                <ComboBoxItem Content="completed"/>
                <ComboBoxItem Content="cancelled"/>
            </ComboBox>
        </StackPanel>

        <ListView x:Name="lvOrders" Grid.Row="2" Margin="5">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id}" Width="50"/>
                    <GridViewColumn Header="Пользователь" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Users.FullName}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Услуга" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Services.Name}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Дата заказа" DisplayMemberBinding="{Binding OrderDate}" Width="120"/>
                    <GridViewColumn Header="Адрес" DisplayMemberBinding="{Binding PickupAddress}" Width="200"/>
                    <GridViewColumn Header="Время получения" DisplayMemberBinding="{Binding PickupTime}" Width="120"/>
                    <GridViewColumn Header="Оплата" DisplayMemberBinding="{Binding PaymentMethod}" Width="80"/>
                    <GridViewColumn Header="Статус" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <Button Content="Изменить" Width="60" Height="20" FontSize="10" 
                                            Click="ChangeStatus_Click" Tag="{Binding Id}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Button x:Name="btnBack" Content="Назад" Grid.Row="3" Width="100" Height="30" Margin="5" HorizontalAlignment="Right" Click="btnBack_Click"/>
    </Grid>
</Page>