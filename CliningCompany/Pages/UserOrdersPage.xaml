<Page x:Class="CliningCompany.Pages.UserOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои заказы" Background="LightGray">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Мои заказы" FontSize="18" FontWeight="Bold" Margin="10"/>

        <ListView x:Name="lvOrders" Grid.Row="1" Margin="10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Услуга" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Services.Name}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Дата заказа" DisplayMemberBinding="{Binding OrderDate}" Width="150"/>
                    <GridViewColumn Header="Адрес самовывоза" DisplayMemberBinding="{Binding PickupAddress}" Width="320"/>
                    <GridViewColumn Header="Время получения" DisplayMemberBinding="{Binding PickupTime}" Width="150"/>
                    <GridViewColumn Header="Способ оплаты" DisplayMemberBinding="{Binding PaymentMethod}" Width="110"/>
                    <GridViewColumn Header="Статус" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <Button Content="Отменить" Width="60" Height="20" FontSize="10" 
                                            Visibility="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=paid}"
                                            Click="CancelOrder_Click" Tag="{Binding Id}"/>
                                    <Button Content="Отзыв" Width="60" Height="20" FontSize="10" 
                                            Visibility="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=completed}"
                                            Click="AddReview_Click" Tag="{Binding Id}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Button x:Name="btnBack" Content="Назад" Grid.Row="2" Width="100" Height="30" Margin="10" HorizontalAlignment="Right" Click="btnBack_Click"/>
    </Grid>
</Page>