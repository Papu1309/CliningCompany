<Page x:Class="CliningCompany.Pages.UserProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль" Background="LightGray">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Мой профиль" FontSize="18" FontWeight="Bold" Margin="10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Полное имя:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtFullName" Grid.Row="1" Grid.Column="1" Margin="5" IsReadOnly="True" Background="#f0f0f0"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Логин:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtUsername" Grid.Row="2" Grid.Column="1" Margin="5" IsReadOnly="True" Background="#f0f0f0"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Новый пароль:" Margin="5" VerticalAlignment="Center"/>
        <PasswordBox x:Name="txtNewPassword" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Подтвердите:" Margin="5" VerticalAlignment="Center"/>
        <PasswordBox x:Name="txtConfirmPassword" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="btnChangePassword" Content="Сменить пароль" Width="150" Height="30" Margin="5" Click="btnChangePassword_Click"/>
            <Button x:Name="btnBack" Content="Назад" Width="100" Height="30" Margin="5" Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Page>