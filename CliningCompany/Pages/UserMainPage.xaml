<Page x:Class="CliningCompany.Pages.UserMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Услуги" Background="LightGray">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Доступные услуги" FontSize="18" FontWeight="Bold" Margin="10"/>

        <!-- Поиск по названию -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtSearch" Width="200" Padding="3" TextChanged="txtSearch_TextChanged"/>
        </StackPanel>

        <!-- Список услуг с категориями -->
        <ListView x:Name="lvServices" Grid.Row="2" Margin="10" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Категория" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Categories.Name}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price}" Width="100"/>
                    <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding Description}" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="btnOrder" Content="Заказать выбранную услугу" Width="200" Height="30" Margin="5" Click="btnOrder_Click"/>
            <Button x:Name="btnMyOrders" Content="Мои заказы" Width="100" Height="30" Margin="5" Click="btnMyOrders_Click"/>
            <Button x:Name="btnProfile" Content="Профиль" Width="100" Height="30" Margin="5" Click="btnProfile_Click"/>
            <Button x:Name="btnLogout" Content="Выход" Width="100" Height="30" Margin="5" Click="btnLogout_Click"/>
        </StackPanel>
    </Grid>
</Page>